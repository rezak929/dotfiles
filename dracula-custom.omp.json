{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#44475a",
          "foreground": "#f8f8f2",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "🐧 ",
          "type": "text"
        },
        {
          "background": "#6272a4",
          "foreground": "#f8f8f2",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "background": "#bd93f9",
          "foreground": "#f8f8f2",
          "powerline_symbol": "\ue0b0",
          "options": {
            "style": "folder"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#06355e",
          "foreground": "#fcfcfc",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": false,
            "ignore_submodules": true
          },
          "style": "powerline",
          "template": " 🌿 {{ .HEAD }}{{ if .Working.Changed }} !{{ .Working.String }}{{ end }}{{ if .Staging.Changed }} +{{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} stash:{{ .StashCount }}{{ end }}{{ if gt .Behind 0 }} <#8be9fd>⇣{{ .Behind }}</>{{ end }}{{ if gt .Ahead 0 }} <#50fa7b>⇡{{ .Ahead }}</>{{ end }} ",
          "type": "git"
        },
        {
          "background": "#8be9fd",
          "foreground": "#282a36",
          "powerline_symbol": "\ue0b0",
          "options": {
            "fetch_context": true,
            "fetch_namespace": true
          },
          "style": "powerline",
          "template": " ☸️  {{ .Context }}{{ if .Namespace }}:{{ .Namespace }}{{ end }} ",
          "type": "kubectl"
        },
        {
          "background": "#50fa7b",
          "foreground": "#282a36",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " 🐳 {{ .Output }} ",
          "type": "docker",
          "options": {
            "display_mode": "always"
          }
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#ff79c6",
          "foreground": "#f8f8f2",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": " {{ .CurrentDate | date .Format }} 🕑 ",
          "trailing_diamond": "\ue0b4",
          "type": "time",
          "options": {
            "time_format": "3:04 PM"
          }
        }
      ],
      "type": "rprompt"
    }
  ],
  "final_space": true,
  "version": 4
}
